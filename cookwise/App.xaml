<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:cookwise"
             xmlns:converters="clr-namespace:cookwise.Converters"
             x:Class="cookwise.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <local:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <local:HasValueConverter x:Key="HasValueConverter"/>
            <converters:FirstCharConverter x:Key="FirstCharConverter"/>
            <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
