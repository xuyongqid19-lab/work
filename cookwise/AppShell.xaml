<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="cookwise.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:cookwise.Views"
    Title="CookWise">

    <FlyoutItem Title="Home" Icon="house">
        <ShellContent ContentTemplate="{DataTemplate views:HomePage}" Route="HomePage" />
    </FlyoutItem>
    <FlyoutItem Title="Search" Icon="search">
        <ShellContent ContentTemplate="{DataTemplate views:SearchPage}" Route="SearchPage" />
    </FlyoutItem>
    <FlyoutItem Title="Notes" Icon="note">
        <ShellContent ContentTemplate="{DataTemplate views:NotePage}" Route="NotePage" />
    </FlyoutItem>

</Shell>
