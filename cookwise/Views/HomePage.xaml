<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:cookwise.ViewModels"
             x:Class="cookwise.Views.HomePage"
             x:Name="HomePageRoot"
             Title="CookWise">
    <ContentPage.BindingContext>
        <vm:HomeViewModel />
    </ContentPage.BindingContext>
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            <VerticalStackLayout Spacing="5">
                <Label Text="CookWise" FontSize="32" FontAttributes="Bold" TextColor="#FF6B35"/>
                <Label Text="Precision Cooking Laboratory" FontSize="16" TextColor="Gray"/>
</VerticalStackLayout>

            <Border BackgroundColor="#E8F5E9" Padding="15" StrokeShape="RoundRectangle 8">
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                    <VerticalStackLayout HorizontalOptions="Center" Grid.Column="0">
                        <Label Text="Recipes" FontSize="10" TextColor="#2E7D32" HorizontalOptions="Center"/>
                        <Label Text="{Binding TotalRecipes, StringFormat='{0}'}" FontSize="20" FontAttributes="Bold" TextColor="#2E7D32" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout HorizontalOptions="Center" Grid.Column="1">
                        <Label Text="Ingredients" FontSize="10" TextColor="#1565C0" HorizontalOptions="Center"/>
                        <Label Text="{Binding TotalIngredients, StringFormat='{0}'}" FontSize="20" FontAttributes="Bold" TextColor="#1565C0" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout HorizontalOptions="Center" Grid.Column="2">
                        <Label Text="Avg Cost" FontSize="10" TextColor="#E65100" HorizontalOptions="Center"/>
                        <Label Text="{Binding AvgCost, StringFormat='${0:F2}'}" FontSize="20" FontAttributes="Bold" TextColor="#E65100" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                    <VerticalStackLayout HorizontalOptions="Center" Grid.Column="3">
                        <Label Text="Avg Cal" FontSize="10" TextColor="#AD1457" HorizontalOptions="Center"/>
                        <Label Text="{Binding AvgCalories, StringFormat='{0}'}" FontSize="20" FontAttributes="Bold" TextColor="#AD1457" HorizontalOptions="Center"/>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold"/>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <Button Text="Search" 
                        BackgroundColor="#FFF3E0" 
                        TextColor="#E65100"
                        Grid.Column="0"
                        Command="{Binding SearchCommand}"/>
                <Button Text="Notes" 
                        BackgroundColor="#E3F2FD" 
                        TextColor="#1565C0"
                        Grid.Column="1"
                        Command="{Binding NotesCommand}"/>
                <Button Text="Profile" 
                        BackgroundColor="#FCE4EC" 
                        TextColor="#AD1457"
                        Grid.Column="2"
                        Command="{Binding ProfileCommand}"/>
            </Grid>

            <Label Text="Featured Recipes" FontSize="18" FontAttributes="Bold"/>
            <CollectionView ItemsSource="{Binding FeaturedRecipes}" HeightRequest="180" SelectionMode="Single" SelectedItem="{Binding SelectedRecipe}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="15"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" WidthRequest="150" Padding="10" StrokeShape="RoundRectangle 8">
                            <VerticalStackLayout>
                                <Border Padding="0" StrokeShape="RoundRectangle 15" HeightRequest="100"
                                        BackgroundColor="#FFE4B5" Stroke="Transparent">
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                </Border>
                                <Label Text="{Binding Name}" FontSize="14" FontAttributes="Bold" Margin="0,8,0,2"/>
                                <Label Text="{Binding Description}" FontSize="10" TextColor="Gray" MaxLines="2"/>
                                <Label Text="{Binding EstimatedCost, StringFormat='${0:F2}'}" FontSize="10" TextColor="#FF6B35"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Label Text="All Recipes" FontSize="18" FontAttributes="Bold"/>
            <CollectionView ItemsSource="{Binding AllRecipes}" SelectionMode="Single" SelectedItem="{Binding SelectedRecipe}">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="White" Padding="15" StrokeShape="RoundRectangle 8">
                            <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="15">
                                <Border Padding="0" StrokeShape="RoundRectangle 10" WidthRequest="80" HeightRequest="80" Grid.Column="0"
                                        BackgroundColor="#FFE4B5" Stroke="Transparent">
                                    <Image Source="{Binding ImageUrl}"
                                           Aspect="AspectFill"
                                           HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold"/>
                                    <Label Text="{Binding Description}" FontSize="12" TextColor="Gray"/>
                                    <Label Text="{Binding Servings, StringFormat='{0} Servings'}" FontSize="10" TextColor="Gray"/>
                                </VerticalStackLayout>
                                <Label Text=">" FontSize="20" TextColor="Gray" Grid.Column="2" VerticalOptions="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
