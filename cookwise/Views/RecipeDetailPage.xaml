<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:cookwise.ViewModels"
             x:Class="cookwise.Views.RecipeDetailPage"
             x:Name="ThisPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">
    <ContentPage.BindingContext>
        <vm:RecipeDetailViewModel />
    </ContentPage.BindingContext>
    
    <Grid>
        <ScrollView>
            <Grid RowDefinitions="300, *">
                <!-- 2. Food Image Area -->
                <Frame Grid.Row="0" BackgroundColor="#FFE4B5" Padding="0">
                    <Label Text="{Binding Recipe.Name, Converter={StaticResource FirstCharConverter}}" 
                           FontSize="72" FontAttributes="Bold" TextColor="#FF6B35"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Frame>
                
                <!-- Main Content Area with rounded top corners overlapping the image -->
                <Frame Grid.Row="1" BackgroundColor="White" CornerRadius="30" Margin="0,-30,0,0" Padding="25" HasShadow="False" BorderColor="Transparent">
                    <VerticalStackLayout Spacing="20">
                        
                        <!-- 3. Recipe Name and Summary Area -->
                        <Grid ColumnDefinitions="*,Auto">
                            <Label Text="{Binding Recipe.Name}" FontSize="28" FontAttributes="Bold" TextColor="#333333" VerticalOptions="Center"/>
                            <Button Text="❤️" Command="{Binding ToggleFavoriteCommand}" BackgroundColor="#FFF0F5" TextColor="Red" CornerRadius="20" WidthRequest="40" HeightRequest="40" Padding="0" Grid.Column="1" VerticalOptions="Center"/>
                        </Grid>
                        
                        <HorizontalStackLayout Spacing="20">
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="🕒" FontSize="16" VerticalOptions="Center"/>
                                <Label Text="{Binding Recipe.CookingTime, StringFormat='Cooking Time: {0}'}" FontSize="14" TextColor="#666666" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="🔥" FontSize="16" VerticalOptions="Center"/>
                                <Label Text="{Binding Recipe.Calories, StringFormat='Calories: {0} kcal'}" FontSize="14" TextColor="#666666" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>

                        <!-- 4. Ingredients List Area -->
                        <Grid ColumnDefinitions="*,Auto" Margin="0,15,0,5">
                            <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                                <Label Text="🛒" FontSize="20" VerticalOptions="Center"/>
                                <Label Text="Ingredients" FontSize="20" FontAttributes="Bold" TextColor="#333333" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Button Text="+ Save Recipe" Command="{Binding SaveRecipeCommand}" Grid.Column="1" BackgroundColor="#FFE0B2" TextColor="#E65100" CornerRadius="18" HeightRequest="36" Padding="15,0" FontAttributes="Bold" VerticalOptions="Center"/>
                        </Grid>
                        
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Recipe.Ingredients}" Spacing="10">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="#F8F9FA" Padding="15,10" CornerRadius="15" HasShadow="False" BorderColor="Transparent">
                                        <Grid ColumnDefinitions="Auto,*,Auto">
                                            <!-- Left: Small icon -->
                                            <Label Text="{Binding IconUrl}" FontSize="24" VerticalOptions="Center" Grid.Column="0" Margin="0,0,15,0"/>
                                            
                                            <!-- Middle: Amount and Name -->
                                            <HorizontalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                                <Label Text="{Binding Grams, StringFormat='{0}g'}" FontAttributes="Bold" TextColor="#333333"/>
                                                <Label Text="{Binding Name}" TextColor="#555555"/>
                                            </HorizontalStackLayout>
                                            
                                            <!-- Right: Round button with heart -->
                                            <Button Text="❤️" BackgroundColor="White" CornerRadius="15" WidthRequest="30" HeightRequest="30" Padding="0" FontSize="12" Grid.Column="2" VerticalOptions="Center" BorderColor="#DDDDDD" BorderWidth="1"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>

                        <!-- 5. Cooking Steps Area -->
                        <HorizontalStackLayout Spacing="8" Margin="0,15,0,5">
                            <Label Text="📎" FontSize="20" VerticalOptions="Center"/>
                            <Label Text="Steps" FontSize="20" FontAttributes="Bold" TextColor="#333333" VerticalOptions="Center"/>
                        </HorizontalStackLayout>
                        
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Recipe.Steps}" Spacing="15">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Grid RowDefinitions="Auto,Auto" Margin="0,5">
                                        <!-- Step Number and Timer Button -->
                                        <Grid ColumnDefinitions="Auto,*,Auto" Grid.Row="0">
                                            <!-- Step Number -->
                                            <Frame BackgroundColor="#FFF3E0" CornerRadius="15" WidthRequest="30" HeightRequest="30" Padding="0" Grid.Column="0" VerticalOptions="Start" Margin="0,0,10,0" HasShadow="False" BorderColor="Transparent">
                                                <Label Text="{Binding StepNumber}" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#E65100" FontAttributes="Bold"/>
                                            </Frame>
                                            
                                            <!-- Step Description -->
                                            <Label Text="{Binding Description}" FontSize="15" TextColor="#444444" Grid.Column="1" VerticalOptions="Center" LineHeight="1.4"/>
                                            
                                            <!-- Timer Button -->
                                            <Button Text="⏱"
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.StartTimerCommand}"
                                                    CommandParameter="{Binding}"
                                                    BackgroundColor="#4CAF50"
                                                    TextColor="White"
                                                    CornerRadius="15"
                                                    WidthRequest="36"
                                                    HeightRequest="36"
                                                    Padding="0"
                                                    FontSize="16"
                                                    Grid.Column="2"
                                                    VerticalOptions="Center"
                                                    Margin="5,0,0,0">
                                                <Button.IsVisible>
                                                    <Binding Path="DurationMinutes">
                                                        <Binding.Converter>
                                                            <local:HasValueConverter xmlns:local="clr-namespace:cookwise"/>
                                                        </Binding.Converter>
                                                    </Binding>
                                                </Button.IsVisible>
                                            </Button>
                                        </Grid>
                                        
                                        <!-- Duration Info -->
                                        <HorizontalStackLayout Grid.Row="1" Margin="45,5,0,0" Spacing="10">
                                            <Label Text="{Binding DurationMinutes, StringFormat='⏱ {0} min'}" 
                                                   FontSize="12" 
                                                   TextColor="#888888">
                                                <Label.IsVisible>
                                                    <Binding Path="DurationMinutes">
                                                        <Binding.Converter>
                                                            <local:HasValueConverter xmlns:local="clr-namespace:cookwise"/>
                                                        </Binding.Converter>
                                                    </Binding>
                                                </Label.IsVisible>
                                            </Label>
                                            <Label Text="{Binding HeatLevel, StringFormat='🔥 {0}'}" 
                                                   FontSize="12" 
                                                   TextColor="#FF7043">
                                                <Label.IsVisible>
                                                    <Binding Path="HeatLevel">
                                                        <Binding.Converter>
                                                            <converters:StringToBoolConverter xmlns:converters="clr-namespace:cookwise.Converters"/>
                                                        </Binding.Converter>
                                                    </Binding>
                                                </Label.IsVisible>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                        
                        <BoxView HeightRequest="40" Color="Transparent" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </ScrollView>
        
        <!-- Timer Display Overlay -->
        <Frame IsVisible="{Binding HasActiveTimer}"
               BackgroundColor="#E3F2FD"
               CornerRadius="20"
               Padding="20"
               Margin="20"
               HorizontalOptions="Center"
               VerticalOptions="End"
               HasShadow="True"
               BorderColor="#2196F3"
               x:Name="TimerDisplay">
            <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                <!-- Timer Display -->
                <Label Text="{Binding ActiveTimerDisplay}"
                       FontSize="48"
                       FontAttributes="Bold"
                       TextColor="#1976D2"
                       HorizontalOptions="Center"
                       FontFamily="monospace"/>
                
                <!-- Warning Text (last 10 seconds) -->
                <Label Text="{Binding TimerWarningText}"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="#F44336"
                       HorizontalOptions="Center"
                       IsVisible="{Binding IsCountdownWarning}">
                    <Label.Triggers>
                        <DataTrigger TargetType="Label" Binding="{Binding IsCountdownWarning}" Value="True">
                            <Setter Property="TextColor" Value="#F44336"/>
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
                
                <!-- Stop Button -->
                <Button Text="⏹ 停止计时"
                        Command="{Binding StopTimerCommand}"
                        BackgroundColor="#F44336"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40"
                        FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Frame>
        
        <!-- 1. Top Navigation Bar (Floating) -->
        <HorizontalStackLayout Margin="20,40,20,0" VerticalOptions="Start" HorizontalOptions="Start">
            <Button Text="← Back" Command="{Binding GoBackCommand}" BackgroundColor="#66000000" TextColor="White" CornerRadius="20" HeightRequest="40" Padding="15,0" FontAttributes="Bold"/>
        </HorizontalStackLayout>
    </Grid>
</ContentPage>