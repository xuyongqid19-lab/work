<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:cookwise.ViewModels"
             x:Class="cookwise.Views.SearchPage"
             Title="Search">
    <ContentPage.BindingContext>
        <vm:SearchViewModel />
    </ContentPage.BindingContext>
    
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- ══════════════════════════════════════════ -->
            <!--  AI 菜品生成区                             -->
            <!-- ══════════════════════════════════════════ -->
            <Frame BackgroundColor="#FFF3E0" BorderColor="#FF6B35" Padding="16" CornerRadius="12">
                <VerticalStackLayout Spacing="12">

                    <!-- 标题 -->
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="✨" FontSize="20" VerticalOptions="Center"/>
                        <Label Text="AI 智能生成菜品" FontSize="18" FontAttributes="Bold" TextColor="#E64A19" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="输入一种食材，AI 为你推荐最搭配的菜肴" FontSize="13" TextColor="#757575"/>

                    <!-- 食材输入框 + 生成按钮 -->
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                        <Frame Grid.Column="0" BackgroundColor="White" Padding="4,0" CornerRadius="8" BorderColor="#FFCCBC">
                            <Entry x:Name="AiIngredientEntry"
                                   Placeholder="例如：土豆、茄子、西红柿..."
                                   Text="{Binding AiIngredientInput, Mode=TwoWay}"
                                   FontSize="14"
                                   ReturnCommand="{Binding GenerateRecipesCommand}"/>
                        </Frame>
                        <Button Grid.Column="1"
                                Text="生成"
                                Command="{Binding GenerateRecipesCommand}"
                                BackgroundColor="#FF6B35"
                                TextColor="White"
                                FontSize="15"
                                FontAttributes="Bold"
                                CornerRadius="8"
                                HeightRequest="44"
                                WidthRequest="70"
                                IsEnabled="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}"/>
                    </Grid>

                    <!-- 加载动画 -->
                    <VerticalStackLayout IsVisible="{Binding IsGenerating}" Spacing="8" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="{Binding IsGenerating}" Color="#FF6B35" HeightRequest="36" WidthRequest="36" HorizontalOptions="Center"/>
                        <Label Text="AI 正在为您推荐菜品..." FontSize="13" TextColor="#FF6B35" HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- 状态文字 -->
                    <Label Text="{Binding GenerateStatusText}"
                           FontSize="13"
                           TextColor="#616161"
                           IsVisible="{Binding IsGenerating, Converter={StaticResource InverseBoolConverter}}"
                           HorizontalOptions="Center"/>

                    <!-- 生成结果列表 -->
                    <CollectionView ItemsSource="{Binding GeneratedRecipes}"
                                    IsVisible="{Binding HasGeneratedResults}"
                                    SelectionMode="None">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame BackgroundColor="White" Padding="14" CornerRadius="10"
                                       BorderColor="#FFCCBC">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                        <!-- 菜名 -->
                                        <HorizontalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                            <Label Text="🍽️" FontSize="16" VerticalOptions="Center"/>
                                            <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" TextColor="#212121" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <!-- 烹饪时间 + 卡路里 -->
                                        <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Spacing="12">
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="⏱" FontSize="12" TextColor="#9E9E9E" VerticalOptions="Center"/>
                                                <Label Text="{Binding CookingTime}" FontSize="12" TextColor="#9E9E9E" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="4">
                                                <Label Text="🔥" FontSize="12" TextColor="#9E9E9E" VerticalOptions="Center"/>
                                                <Label FontSize="12" TextColor="#9E9E9E" VerticalOptions="Center">
                                                    <Label.Text>
                                                        <MultiBinding StringFormat="{}{0} kcal">
                                                            <Binding Path="Calories"/>
                                                        </MultiBinding>
                                                    </Label.Text>
                                                </Label>
                                            </HorizontalStackLayout>
                                        </HorizontalStackLayout>

                                        <!-- 描述 -->
                                        <Label Grid.Row="2" Grid.Column="0"
                                               Text="{Binding Description}"
                                               FontSize="12"
                                               TextColor="#757575"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="2"/>

                                        <!-- 查看按钮 -->
                                        <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                                                Text="查看"
                                                Command="{Binding Source={x:Reference AiIngredientEntry}, Path=BindingContext.ViewRecipeCommand}"
                                                CommandParameter="{Binding}"
                                                BackgroundColor="#FF6B35"
                                                TextColor="White"
                                                FontSize="13"
                                                CornerRadius="8"
                                                HeightRequest="40"
                                                WidthRequest="55"
                                                VerticalOptions="Center"
                                                Margin="10,0,0,0"/>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                </VerticalStackLayout>
            </Frame>

            <!-- ══════════════════════════════════════════ -->
            <!--  原有食材搜索区                            -->
            <!-- ══════════════════════════════════════════ -->
            <Label Text="食材搜索" FontSize="20" FontAttributes="Bold" TextColor="#FF6B35" Margin="0,10,0,0"/>
            <Label Text="添加多种食材，匹配已有菜谱" FontSize="13" TextColor="Gray"/>

            <Frame BackgroundColor="#F5F5F5" Padding="10">
                <Grid ColumnDefinitions="*,Auto">
                    <Entry x:Name="IngredientEntry" Placeholder="Tomato, Egg" Text="{Binding IngredientInput, Mode=TwoWay}" Grid.Column="0"/>
                    <Button Text="Add" Command="{Binding AddIngredientCommand}" BackgroundColor="#FF6B35" TextColor="White" Grid.Column="1" Margin="10,0,0,0"/>
                </Grid>
            </Frame>

            <Label Text="已选食材" FontSize="14" FontAttributes="Bold"/>
            <FlexLayout Wrap="Wrap" BindableLayout.ItemsSource="{Binding SelectedIngredients}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#E3F2FD" Padding="10,5" Margin="0,0,5,5">
                            <Label Text="{Binding}" VerticalOptions="Center"/>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <Button Text="搜索菜谱" Command="{Binding SearchCommand}" BackgroundColor="#4CAF50" TextColor="White" FontSize="16" HeightRequest="45"/>

            <Label Text="搜索结果" FontSize="18" FontAttributes="Bold" Margin="0,10,0,0"/>
            <CollectionView ItemsSource="{Binding SearchResults}" HeightRequest="400">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" Padding="15">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="{Binding Recipe.Name}" FontSize="18" FontAttributes="Bold"/>
                                <Label Text="{Binding Recipe.Description}" FontSize="12" TextColor="Gray"/>
                                <Button Text="View" Command="{Binding Source={x:Reference IngredientEntry}, Path=BindingContext.ViewRecipeCommand}" CommandParameter="{Binding Recipe}" BackgroundColor="#FF6B35" TextColor="White"/>
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
